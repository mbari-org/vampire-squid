<?xml version="1.0" encoding="UTF-8"?>

<configuration scan="false" debug="false">

    <statusListener class="ch.qos.logback.core.status.NopStatusListener" />

    <variable name="LOGBACK_LEVEL" value="${LOGBACK_LEVEL:-INFO}" />

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%yellow(%d{yyyy-MM-dd HH:mm:ss.SSS}) %highlight(%-5level) [%green(%-25thread)] %blue(%-40logger{40}) %yellow(|) %msg%n</pattern>
        </encoder>
    </appender>


    <logger name="java" level="WARN" />
    <logger name="jdk" level="WARN" />
    <logger name="org.hibernate" level="error" additivity="false" />
    <logger name="sun" level="WARN" />

    <!-- Hibernate after 6 DEBUG -->
    <!-- <logger name="org.hibernate.cache" level="debug" additivity="false" />
    <logger name="org.hibernate.orm.jdbc.bind" level="trace" additivity="false" />
    <logger name="org.hibernate.SQL_SLOW" level="info" additivity="false" />
    <logger name="org.hibernate.SQL" level="debug" additivity="false" />
    <logger name="org.hibernate.stat" level="debug" additivity="false" /> -->

    <!-- Netty will emit warnings if a client disconnects abruptly. Setting to ERROR suppresses these warnings. -->
    <logger name="io.netty.channel.DefaultChannelPipeline" level="ERROR" />

    <root level="${LOGBACK_LEVEL}">
        <appender-ref ref="CONSOLE" />
    </root>

</configuration>
